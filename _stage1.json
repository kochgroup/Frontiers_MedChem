{
    "run_type": "staged_learning",
    "device": "cpu",
    "use_cuda": true,
    "tb_logdir": "tb_logs_numrotbond",
    "json_out_config": "_stage1.json",
    "seed": null,
    "parameters": {
        "prior_file": "./priors/reinvent.prior",
        "agent_file": "./priors/reinvent.prior",
        "summary_csv_prefix": "stage_numrotbond",
        "use_checkpoint": false,
        "purge_memories": true,
        "smiles_file": null,
        "sample_strategy": "multinomial",
        "distance_threshold": 99999,
        "batch_size": 100,
        "randomize_smiles": true,
        "unique_sequences": false,
        "temperature": 1.0,
        "tb_isim": false
    },
    "scoring": null,
    "scheduler": null,
    "responder": null,
    "filter": null,
    "stage": [
        {
            "max_steps": 10,
            "max_score": 1.0,
            "chkpt_file": "numrotbond_reversesig.chkpt",
            "termination": "simple",
            "min_steps": 5,
            "scoring": {
                "type": "geometric_mean",
                "component": [
                    {
                        "custom_alerts": {
                            "endpoint": [
                                {
                                    "name": "Alerts",
                                    "params": {
                                        "smarts": [
                                            "[*;r8]",
                                            "[*;r9]",
                                            "[*;r10]",
                                            "[*;r11]",
                                            "[*;r12]",
                                            "[*;r13]",
                                            "[*;r14]",
                                            "[*;r15]",
                                            "[*;r16]",
                                            "[*;r17]",
                                            "[#8][#8]",
                                            "[#6;+]",
                                            "[#16][#16]",
                                            "[#7;!n][S;!$(S(=O)=O)]",
                                            "[#7;!n][#7;!n]",
                                            "C#C",
                                            "C(=[O,S])[O,S]",
                                            "[#7;!n][C;!$(C(=[O,N])[N,O])][#16;!s]",
                                            "[#7;!n][C;!$(C(=[O,N])[N,O])][#7;!n]",
                                            "[#7;!n][C;!$(C(=[O,N])[N,O])][#8;!o]",
                                            "[#8;!o][C;!$(C(=[O,N])[N,O])][#16;!s]",
                                            "[#8;!o][C;!$(C(=[O,N])[N,O])][#8;!o]",
                                            "[#16;!s][C;!$(C(=[O,N])[N,O])][#16;!s]"
                                        ]
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "NumRotBond": {
                            "endpoint": [
                                {
                                    "name": "ROTB",
                                    "weight": 1,
                                    "transform": {
                                        "type": "reverse_sigmoid",
                                        "high": 20,
                                        "low": 0,
                                        "k": 0.5
                                    }
                                }
                            ]
                        }
                    }
                ],
                "filename": null
            },
            "diversity_filter": null
        }
    ],
    "learning_strategy": {
        "type": "dap",
        "sigma": 128,
        "rate": 0.0001
    },
    "diversity_filter": {
        "type": "IdenticalMurckoScaffold",
        "bucket_size": 10,
        "minscore": 0.4,
        "minsimilarity": 0.4,
        "penalty_multiplier": 0.5
    },
    "intrinsic_penalty": null,
    "inception": null
}